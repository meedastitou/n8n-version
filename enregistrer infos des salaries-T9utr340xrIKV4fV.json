ghtValue":"EN_ATTENTE_LANGUE","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[496,-496],"id":"c1076075-a356-4e4e-b583-34ebb1e3987e","name":"If1"},{"parameters":{"chatId":"={{ $node['Telegram Trigger1'].json.message.chat.id }}","text":"⚠️ **Inscription incomplète**\n\nVotre code X3 est enregistré, mais votre langue de communication n'a pas encore été sélectionnée.\n\n🌍 **Dernière étape !**\nChoisissez votre langue pour recevoir vos notifications :\n\n👇 Sélectionnez votre langue préférée :","replyMarkup":"inlineKeyboard","inlineKeyboard":{"rows":[{"row":{"buttons":[{"text":"🇫🇷 Français","additionalFields":{"callback_data":"=lang_FRA_{{ $json.Code_X3 }}"}},{"text":"🇬🇧 English","additionalFields":{"callback_data":"=lang_ENG_{{ $json.Code_X3 }}"}}]}},{"row":{"buttons":[{"text":"🇪🇸 Español","additionalFields":{"callback_data":"=lang_ESP_{{ $json.Code_X3 }}"}},{"text":"🇸🇦 العربية","additionalFields":{"callback_data":"=lang_ARA_{{ $json.Code_X3 }}"}}]}}]},"additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[720,-592],"id":"13c14dde-2e5b-4731-8840-3838b566e3f3","name":"Demander Langue1","webhookId":"ba13702c-f10e-40d4-865b-07c7c370762e","credentials":{"telegramApi":{"id":"45w69gDsqGFcxPpu","name":"Notification"}}},{"parameters":{"operation":"executeQuery","query":"SELECT \n    '{{ $json.message.chat.id }}' AS CHAT_ID,\n    '{{ $json.message.text }}' AS CODE_ENVOYE,\n    \n    -- Déterminer l'état de l'utilisateur\n    CASE \n        WHEN EXISTS (\n            SELECT 1\n            FROM jbelrh.JBELRH.YAIINFOSAL\n            WHERE TIDCHAT_0 = '{{ $json.message.chat.id }}'\n              AND XSAL_0 IS NOT NULL \n              AND LAN_0 IS NOT NULL\n              AND LTRIM(RTRIM(LAN_0)) != ''  -- ✅ Vérifier que ce n'est pas juste des espaces\n        )\n        THEN 'ENREGISTRE_COMPLET'\n        \n        WHEN EXISTS (\n            SELECT 1\n            FROM jbelrh.JBELRH.YAIINFOSAL\n            WHERE TIDCHAT_0 = '{{ $json.message.chat.id }}'\n              AND XSAL_0 IS NOT NULL \n              AND (LAN_0 IS NULL OR LTRIM(RTRIM(LAN_0)) = '')  -- ✅ NULL ou vide (avec espaces)\n        )\n        THEN 'EN_ATTENTE_LANGUE'\n        \n        ELSE 'NOUVEAU'\n    END AS ETAT_UTILISATEUR,\n    \n    -- Récupérer le code existant s'il y en a un\n    COALESCE(MAX(t.XSAL_0), NULL) AS Code_X3_Existant,\n    \n    -- Nettoyer la langue (enlever les espaces)\n    CASE \n        WHEN MAX(t.LAN_0) IS NULL THEN NULL\n        WHEN LTRIM(RTRIM(MAX(t.LAN_0))) = '' THEN NULL\n        ELSE LTRIM(RTRIM(MAX(t.LAN_0)))\n    END AS Langue_Existante\n    \nFROM (SELECT 1 AS dummy) dummy_table\nLEFT JOIN jbelrh.JBELRH.YAIINFOSAL t \n    ON t.TIDCHAT_0 = '{{ $json.message.chat.id }}';"},"type":"n8n-nodes-base.microsoftSql","typeVersion":1.1,"position":[48,-16],"id":"18ddee53-d2ae-44a2-ae82-600820b9a71e","name":"Microsoft SQL3","credentials":{"microsoftSql":{"id":"2sA9ZAsYgvC4gdIr","name":"X3BI"}}},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"032e6f38-aae3-4d79-966c-0f36cdc98519","leftValue":"={{ $json.ETAT_UTILISATEUR }}","rightValue":"NOUVEAU","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[272,-16],"id":"de6cd9cf-0412-43c4-a791-fd15396f5c3d","name":"If2"},{"parameters":{"fromEmail":"ai@jbel-annour.ma","toEmail":"={{ $json.user_data.email }}","subject":"code verification","emailFormat":"text","text":"=voici le code de verification de votre code x3 salarier:\n{{ $('If3').item.json.CODE_A_ENVOYER }}","options":{"appendAttribution":false}},"type":"n8n-nodes-base.emailSend","typeVersion":2.1,"position":[1392,-304],"id":"09dd3f0e-0d85-4c51-8190-97fe13794a2c","name":"Send email","webhookId":"3f892b2a-a8ff-4